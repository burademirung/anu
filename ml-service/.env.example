# Environment for the ML container (Cloudflare Container / local `uvicorn`).
# The container is stateless: it holds NO database credentials. It only needs
# R2 (S3 API) credentials to upload report artifacts, plus a Mapbox token for
# fallback imagery. In production these are set as the container's env/secrets.

# R2 (S3-compatible) — create an R2 API token scoped to the `anu` bucket.
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=anu

# Mapbox — fallback satellite imagery when NAIP is unavailable
MAPBOX_ACCESS_TOKEN=pk.ey...
